{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "strict": true,
    "noEmit": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "verbatimModuleSyntax": true,

    "noFallthroughInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "paths": {
        "@/*": ["./src/*"]
    }

  },
  "include": ["src"]
}
